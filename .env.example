# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ticketbooking

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=development

# Mock payment service
PAYMENT_SERVICE_URL=http://localhost:4000
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# Lock TTL in seconds (32 minutes = 1920s)
LOCK_TTL_SECONDS=1920

# Booking window in minutes
BOOKING_WINDOW_MINUTES=30
