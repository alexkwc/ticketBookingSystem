{
  "name": "ticket-booking-system",
  "version": "1.0.0",
  "description": "Distributed ticket booking system with Redis locking, idempotency, outbox pattern, and BullMQ",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node src/scripts/migrate.js",
    "worker:outbox": "node src/workers/outboxWorker.js",
    "worker:jobs": "node src/jobs/bookingCheckWorker.js",
    "payment-mock": "node mock-payment/server.js",
    "load-test": "node load-test/runner.js"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.0.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "chalk": "^4.1.2",
    "nodemon": "^3.0.0"
  }
