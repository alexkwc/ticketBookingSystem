{
  "name": "ticket-booking-system",
  "version": "1.0.0",
  "description": "Distributed ticket booking system with Redis locking, idempotency, outbox pattern, and BullMQ",
  "main": "dist/src/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/app.js",
    "dev": "ts-node src/app.ts",
    "migrate": "node dist/src/scripts/migrate.js",
    "worker:outbox": "node dist/src/workers/outboxWorker.js",
    "worker:jobs": "node dist/src/jobs/bookingCheckWorker.js",
    "payment-mock": "node dist/mock-payment/server.js",
    "load-test": "node dist/load-test/runner.js"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.0.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "chalk": "^4.1.2",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
